# Base de datos (Prisma / SQLite) - necesario para login y portal
DATABASE_URL="file:./prisma/lomadev.db"

# Google AI API Key para Genkit AI
# Obtén tu API key en: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GOOGLE_API_KEY=tu_api_key_aqui
# O alternativamente:
# GEMINI_API_KEY=tu_api_key_aqui

# Google Maps API Key para autocompletado de direcciones
# Obtén tu API key en: https://console.cloud.google.com/apis/credentials
# Asegúrate de habilitar: Places API y Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# Usar datos LOMA en el servidor (herramientas, garantías, personal) para que se sincronicen en todos los dispositivos
# Sin esto, los datos se guardan solo en el navegador (IndexedDB)
NEXT_PUBLIC_USE_SERVER_LOMA=true

# Token para API de salud del servidor (Authorization: Bearer ...)
# Rutas: /api/server/health, /api/server/processes, /api/server/watchdog-log, /api/server/updates
# Genera uno largo aleatorio y úsalo sólo desde cliente de confianza o Tailscale.
SERVER_HEALTH_TOKEN=

# Opcional: ruta al log del miner-watchdog en el servidor
# SERVER_WATCHDOG_LOG_PATH=/var/log/loma-security/miner-watchdog.log

# Otras configuraciones...